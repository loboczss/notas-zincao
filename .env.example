INTEGRIM_BASE_URL=https://absinthe-entity-proven.ngrok-free.dev

# Usuario e senha do CISS Poder. O username precisa ser exatamente o usuario da integracao.
INTEGRIM_USERNAME=Integracaoo
INTEGRIM_PASSWORD=

# Credenciais OAuth do aplicativo Integrim/CISSPoder.
INTEGRIM_CLIENT_ID=cisspoder-oauth
INTEGRIM_CLIENT_SECRET=

INTEGRIM_DEFAULT_MODELO=65
INTEGRIM_COMPANY_IDS=1,2,3,4,5,6

# OpenAI server-only. Use uma chave do projeto da OpenAI.
OPENAI_API_KEY=

# Leitura de cupom fiscal por foto. gpt-5.4-mini e um degrau acima do nano,
# ainda economico, e funciona melhor com texto pequeno de cupom termico.
OPENAI_NOTA_MODEL=gpt-5.4-mini
OPENAI_NOTA_IMAGE_DETAIL=high
OPENAI_NOTA_REASONING_EFFORT=low

# Overrides opcionais, se quiser separar busca fiscal e leitura de produtos.
# OPENAI_NOTA_LOOKUP_MODEL=gpt-5.4-mini
# OPENAI_NOTA_LOOKUP_IMAGE_DETAIL=high
# OPENAI_NOTA_LOOKUP_REASONING_EFFORT=low
# OPENAI_NOTA_PRODUCTS_MODEL=gpt-5.4-mini
# OPENAI_NOTA_PRODUCTS_IMAGE_DETAIL=high
# OPENAI_NOTA_PRODUCTS_REASONING_EFFORT=low
