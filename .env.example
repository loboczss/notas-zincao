# Supabase server/client configuration.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend server-only email configuration.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Integrim/CISS Poder server-only configuration.
INTEGRIM_BASE_URL=https://example.integrim.local
INTEGRIM_USERNAME=
INTEGRIM_PASSWORD=

# Credenciais OAuth do aplicativo Integrim/CISS Poder.
INTEGRIM_CLIENT_ID=
INTEGRIM_CLIENT_SECRET=

INTEGRIM_DEFAULT_MODELO=
INTEGRIM_COMPANY_IDS=

# Sincronizacao automatica do Stock Integrin no servidor.
# Padrao: todos os dias as 02:00 no horario de Sao Paulo.
STOCK_INTEGRIN_AUTO_SYNC_ENABLED=true
STOCK_INTEGRIN_AUTO_SYNC_TIME=02:00
STOCK_INTEGRIN_AUTO_SYNC_TIMEZONE=America/Sao_Paulo

# Sincronizacao automatica das Notas do Integrim (previsao de compras).
# Padrao: todos os dias as 03:00 (escalonado em relacao ao stock).
# INTEGRIM_NOTAS_WINDOW_MONTHS define a janela movel de historico baixado.
INTEGRIM_NOTAS_AUTO_SYNC_ENABLED=true
INTEGRIM_NOTAS_AUTO_SYNC_TIME=03:00
INTEGRIM_NOTAS_AUTO_SYNC_TIMEZONE=America/Sao_Paulo
INTEGRIM_NOTAS_WINDOW_MONTHS=24

# OpenAI server-only. Use uma chave do projeto da OpenAI.
OPENAI_API_KEY=
OPENAI_COMPRA_OPPORTUNITY_MODEL=

# Leitura de cupom fiscal por foto.
OPENAI_NOTA_MODEL=
OPENAI_NOTA_IMAGE_DETAIL=high
OPENAI_NOTA_REASONING_EFFORT=low

# Overrides opcionais, se quiser separar busca fiscal e leitura de produtos.
# OPENAI_NOTA_LOOKUP_MODEL=
# OPENAI_NOTA_LOOKUP_IMAGE_DETAIL=high
# OPENAI_NOTA_LOOKUP_REASONING_EFFORT=low
# OPENAI_NOTA_PRODUCTS_MODEL=
# OPENAI_NOTA_PRODUCTS_IMAGE_DETAIL=high
# OPENAI_NOTA_PRODUCTS_REASONING_EFFORT=low
